{
    "name": "phalcon/phql",
    "description": "Phalcon Query Language (PHQL)",
    "keywords": [
        "php",
        "framework",
        "query",
        "sql"
    ],
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "ext-mbstring": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Phalcon\\Phql\\": "src/"
        },
        "files": [
            "resources/files/parser.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Phalcon\\Phql\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-html coverage"
    }
}
